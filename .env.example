# Copy to .env and fill in as each milestone needs them. All optional until their milestone.

# --- M1: Bluesky analytics fetch (free) ---
# Create an app password at https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# --- M4+: image generation + transcription (Gemini) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- M5: voiceover TTS ---
# https://elevenlabs.io (Starter ~$6/mo)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- M7: publishing ---
# https://typefully.com/settings/api
TYPEFULLY_API_KEY=
# YouTube OAuth — see docs/setup-youtube-oauth.md
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- Optional: Grok X-native polish (off by default in config/providers.yaml) ---
OPENROUTER_API_KEY=
