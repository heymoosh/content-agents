# Copy to .env and fill in as each milestone needs them. All optional until their milestone.

# --- M1: Bluesky analytics fetch (free) ---
# Create an app password at https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# --- M4+: image generation + transcription (Gemini) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Voiceover TTS ---
# Default is Kokoro (local + free) — see docs/setup-kokoro.md.
#   server mode: run kokoro-fastapi (Docker) and point KOKORO_URL at it
#   cli mode (lightweight, no Docker): KOKORO_MODE=cli + KOKORO_CMD=scripts/kokoro-tts
#     (Kokoro-ONNX in a local venv — see "Option C" in docs/setup-kokoro.md)
KOKORO_MODE=server
KOKORO_URL=http://localhost:8880/v1/audio/speech
KOKORO_VOICE=af_heart
# cli mode:
# KOKORO_MODE=cli
# KOKORO_CMD=/absolute/path/to/repo/scripts/kokoro-tts
# KOKORO_CMD=kokoro-tts
# Kokoro emits no timestamps → captions come from a Whisper forced-alignment pass:
WHISPER_BACKEND=whispercpp
WHISPER_CPP_BIN=whisper-cli           # whisper.cpp binary on PATH (or absolute path)
WHISPER_CPP_MODEL=models/ggml-base.en.bin
# Fallback TTS — set tts: elevenlabs in config/providers.yaml to use it (~$6/mo, timestamps built in)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- M7: publishing ---
# https://typefully.com/settings/api  (covers X + LinkedIn + Bluesky as scheduled drafts)
TYPEFULLY_API_KEY=
# YouTube OAuth — see docs/setup-youtube-oauth.md
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
# TikTok via PostPeer (sanctioned API relay; 20 free posts/mo, then never-expiring credits) — see docs/setup-tiktok.md
POSTPEER_API_KEY=
POSTPEER_TIKTOK_ACCOUNT_ID=            # the connected TikTok account's accountId (list accounts in PostPeer to get it)
# TIKTOK_SCHEDULE_AT=                  # explicit ISO-8601 time to schedule the post; omit to use the lead time below
# TIKTOK_SCHEDULE_LEAD_MIN=60          # with no TIKTOK_SCHEDULE_AT, schedule this many minutes after /publish runs

# --- OpenRouter (Grok script writer + image-gen bakeoff) ---
# One key powers both: the video-script writer AND every OpenRouter image model in the
# `npm run bakeoff` lineup (config/bakeoff.yaml). https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_GROK_MODEL=x-ai/grok-4
# OPENROUTER_GROK_COST_PER_1K=0.015    # approx output cost per 1k tokens, for the cost log
